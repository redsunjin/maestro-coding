{
  "name": "maestro-coding",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node maestro-server.js",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node --test tests/*.test.mjs",
    "test:ui": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "smoke:integration": "sh scripts/smoke-agent-integration.sh",
    "qa": "sh scripts/qa-agent.sh",
    "setup": "sh scripts/setup_env.sh",
    "configure": "node scripts/configure.js"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^28.1.0",
    "prompts": "^2.4.2",
    "tailwindcss": "^4.1.6",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "ws": "^8.19.0"
  }
}
