# .env.example — 환경변수 설정 예시
# 이 파일을 복사하여 .env 로 이름을 변경하고 실제 값을 입력하세요.
# .env 파일은 절대 커밋하지 마세요.

# 병합을 수행할 메인 레포지토리의 로컬 절대 경로 (필수)
MAIN_REPO_PATH=/path/to/your/main/repo

# 서버 리스닝 포트 (선택, 기본값: 8080)
PORT=8080

# 프론트엔드가 연결할 WebSocket 주소 (선택, 기본값: ws://localhost:8080)
VITE_WS_URL=ws://localhost:8080

# API 인증 토큰 (선택, 설정 시 /api/request 에 Bearer 인증 활성화)
MAESTRO_SERVER_TOKEN=your-secret-token-here
